# API Configuration
VITE_API_BASE_URL=http://localhost:8000

# Blockchain Configuration
VITE_CONTRACT_ADDRESS=0x...
VITE_CHAIN_ID=1337
VITE_RPC_URL=http://127.0.0.1:8545

# Pinata Gateway Configuration
# 主流程通过后端上传，不需要前端配置 Pinata JWT
# VITE_PINATA_JWT_TOKEN=
VITE_PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# Optional: Custom Gateway (if you have dedicated gateway)
# VITE_PINATA_GATEWAY_URL=https://your-custom-gateway.mypinata.cloud/ipfs
